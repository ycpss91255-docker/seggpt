
[image]
rule_1 = string:seggpt

[volumes]
# Workspace mount. Two reasons this needs to live in setup.conf.local:
#   1. setup.sh's _load_setup_conf reads setup.conf.local + falls back to
#      template/setup.conf (where mount_1 = "" empty). The repo's own
#      docker/setup.conf is NOT in that lookup chain, so without an entry
#      here the mount silently vanishes from compose.yaml.
#   2. setup.sh's auto-detect picks the colocated `_ws` parent
#      (coresam_ws) as WS_PATH — pointing ~/work at the parent shows
#      only `src/` instead of the seggpt repo, which breaks the
#      entrypoint's `${HOME}/work/pyproject.toml` auto-install check.
#
# Anchor mount_1 at WS_PATH/src/seggpt so the container sees the seggpt
# repo directly at /home/${USER_NAME}/work. Portable across machines —
# each contributor's WS_PATH is auto-detected, the relative
# `src/seggpt` suffix stays valid as long as the repo lives under
# `<workspace>/src/seggpt/` (the layout this fork ships with).
mount_1 = ${WS_PATH}/src/seggpt:/home/${USER_NAME}/work

[environment]
env_1 = SEGGPT_BACKEND_NAME=seggpt_vit_l
env_2 = SEGGPT_REFERENCE_MODE=named
env_3 = SEGGPT_PROMPTS_DIR=/workspace/prompts
env_4 = SEGGPT_MODEL_PATH=/workspace/model/seggpt_vit_large.pth
env_5 = SEGGPT_API_PORT=8888
